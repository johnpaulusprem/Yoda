# ═══════════════════════════════════════════════════════════════════
# YODA — Consolidated Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_NAME=
DEBUG=
LOG_LEVEL=
LOG_JSON=
REQUIRE_AUTH=

# ── Database (PostgreSQL + asyncpg) ──────────────────────────────
DATABASE_URL=postgresql+asyncpg://yoda:yoda_dev@localhost:5432/yoda
DATABASE_POOL_SIZE=
DATABASE_MAX_OVERFLOW=

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=

# ── Azure Entra ID (App Registration — daemon flow) ─────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Azure AI Foundry (LLM) ──────────────────────────────────────
AI_FOUNDRY_ENDPOINT=https://your-endpoint.openai.azure.com/
AI_FOUNDRY_API_KEY=your-api-key
AI_FOUNDRY_DEPLOYMENT=
AI_FOUNDRY_DEPLOYMENT_NAME=
AI_FOUNDRY_DEPLOYMENT_NAME_COMPLEX=

# ── Azure OpenAI Embeddings ─────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_EMBEDDING_KEY=your-embedding-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
EMBEDDING_DIMENSIONS=

# ── Azure Communication Services ────────────────────────────────
ACS_CONNECTION_STRING=
ACS_ENDPOINT=
ACS_CALLBACK_BASE_URL=
ACS_CALLBACK_SECRET=

# ── Azure Speech SDK (Browser Bot) ──────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_ENDPOINT=

# ── Graph API ────────────────────────────────────────────────────
GRAPH_WEBHOOK_SECRET=

# ── Public URLs ──────────────────────────────────────────────────
BASE_URL=
BROWSER_BOT_BASE_URL=
BROWSER_BOT_API_KEY=

# ── CORS (Frontend) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=

# ── Inter-Service Authentication ─────────────────────────────────
INTER_SERVICE_HMAC_KEY=
HMAC_SECRET=
API_KEY=

# ── Browser Bot (Node.js) ───────────────────────────────────────
PORT=
PYTHON_BACKEND_URL=
BOT_NAME=
BOT_DISPLAY_NAME=
NODE_ENV=
ENABLE_DEBUG_SCREENSHOTS=
HEADED=

# ── Bot Behavior ─────────────────────────────────────────────────
AUTO_JOIN_ENABLED=
BOT_JOIN_BEFORE_MINUTES=
NUDGE_CHECK_INTERVAL_MINUTES=
NUDGE_COOLDOWN_HOURS=
NUDGE_ESCALATION_THRESHOLD=
ESCALATION_DAYS=
LONG_MEETING_THRESHOLD_MINUTES=

# ── RAG / Chunking ──────────────────────────────────────────────
CHUNK_SIZE=
CHUNK_OVERLAP=

# ── DSPy ─────────────────────────────────────────────────────────
DSPY_CACHE_ENABLED=
DSPY_CACHE_TTL=

# ── Redis Cache TTLs (seconds) ──────────────────────────────────
REDIS_CACHE_KEY_PREFIX=
REDIS_CACHE_DEFAULT_TTL=
REDIS_CACHE_BRIEF_TTL=
REDIS_CACHE_GRAPH_TTL=
REDIS_CACHE_EMBEDDING_TTL=
REDIS_CACHE_LLM_TTL=
REDIS_CACHE_DASHBOARD_TTL=

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_RPM=
RATE_LIMIT_BURST=

# ── Observability (OpenTelemetry) ────────────────────────────────
OTEL_EXPORTER_ENDPOINT=
OTEL_SERVICE_NAME=

# ── Weekly Digest Worker ─────────────────────────────────────────
DIGEST_SCHEDULE_DAY=
DIGEST_SCHEDULE_HOUR=
DIGEST_SCHEDULE_MINUTE=
DIGEST_USER_IDS=
