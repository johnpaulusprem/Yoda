{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "metadata": {
    "webUrl": "${transcript_url}"
  },
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://img.icons8.com/fluency/48/meeting.png",
              "size": "Small",
              "style": "Default",
              "altText": "Meeting icon"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "${meeting_title}",
              "weight": "Bolder",
              "size": "Large",
              "wrap": true
            },
            {
              "type": "TextBlock",
              "text": "${meeting_date} | ${duration} | ${participant_count} participants",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None",
              "wrap": true
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "CXO Brief",
          "weight": "Bolder",
          "size": "Medium",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "${executive_summary}",
          "wrap": true,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Detailed Summary",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small",
                  "id": "summaryToggleLabel"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["summaryContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${summary_text}",
          "wrap": true,
          "id": "summaryContent",
          "isVisible": false,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Key Topics",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["keyTopicsContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${key_topics}",
          "wrap": true,
          "id": "keyTopicsContent",
          "isVisible": false,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Action Items (${action_item_count})",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["actionItemsContent"]
              }
            }
          ]
        },
        {
          "type": "Container",
          "id": "actionItemsContent",
          "isVisible": true,
          "spacing": "Small",
          "items": [
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Description",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "80px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Owner",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "80px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Deadline",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "60px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Priority",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                }
              ]
            },
            {
              "type": "TextBlock",
              "text": "${action_items_rows}",
              "wrap": true,
              "size": "Small",
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Decisions (${decisions_count})",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["decisionsContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${decisions_list}",
          "wrap": true,
          "id": "decisionsContent",
          "isVisible": true,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Sentiment & Engagement",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["sentimentContent"]
              }
            }
          ]
        },
        {
          "type": "Container",
          "id": "sentimentContent",
          "isVisible": false,
          "spacing": "Small",
          "items": [
            {
              "type": "FactSet",
              "facts": [
                {
                  "title": "Overall Sentiment:",
                  "value": "${overall_sentiment}"
                },
                {
                  "title": "Engagement Score:",
                  "value": "${engagement_score}"
                },
                {
                  "title": "Dominant Speaker:",
                  "value": "${dominant_speaker}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Unresolved Questions",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["unresolvedContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${unresolved_questions}",
          "wrap": true,
          "id": "unresolvedContent",
          "isVisible": false,
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Powered by CXO AI Companion",
                  "size": "Small",
                  "isSubtle": true,
                  "horizontalAlignment": "Left"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "AI-generated | ${model_used}",
                  "size": "Small",
                  "isSubtle": true,
                  "horizontalAlignment": "Right"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "View Full Transcript",
      "url": "${transcript_url}",
      "iconUrl": "https://img.icons8.com/fluency/24/document.png"
    },
    {
      "type": "Action.Submit",
      "title": "Request Deep Dive",
      "style": "positive",
      "data": {
        "action": "deep_dive",
        "meeting_id": "${meeting_id}"
      }
    }
  ]
}
