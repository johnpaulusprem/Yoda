{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://img.icons8.com/fluency/48/briefcase.png",
              "size": "Small",
              "style": "Default",
              "altText": "Pre-meeting brief icon"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Pre-Meeting Brief",
              "weight": "Bolder",
              "size": "Large",
              "color": "Accent"
            },
            {
              "type": "TextBlock",
              "text": "Prepared ${minutes_until_meeting} minutes before the meeting",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "${meeting_title}",
          "weight": "Bolder",
          "size": "Medium",
          "wrap": true
        },
        {
          "type": "FactSet",
          "spacing": "Small",
          "facts": [
            {
              "title": "Time:",
              "value": "${meeting_time}"
            },
            {
              "title": "Duration:",
              "value": "${meeting_duration}"
            },
            {
              "title": "Location:",
              "value": "${meeting_location}"
            },
            {
              "title": "Organizer:",
              "value": "${meeting_organizer}"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Attendees (${attendee_count})",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "Container",
          "spacing": "Small",
          "items": [
            {
              "type": "ColumnSet",
              "columns": [
                {
                  "type": "Column",
                  "width": "stretch",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Name",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "80px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Role",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "90px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Last Met",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                },
                {
                  "type": "Column",
                  "width": "70px",
                  "items": [
                    {
                      "type": "TextBlock",
                      "text": "Open Items",
                      "weight": "Bolder",
                      "size": "Small"
                    }
                  ]
                }
              ]
            },
            {
              "type": "TextBlock",
              "text": "${attendee_rows}",
              "wrap": true,
              "size": "Small",
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "$when": "${has_overdue_items}",
      "items": [
        {
          "type": "TextBlock",
          "text": "Overdue Items from Attendees",
          "weight": "Bolder",
          "size": "Medium",
          "color": "Attention"
        },
        {
          "type": "TextBlock",
          "text": "${overdue_items_text}",
          "wrap": true,
          "size": "Small",
          "spacing": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "$when": "${has_last_meeting_decisions}",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Decisions from Last Meeting",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["lastDecisionsContent"]
              }
            }
          ]
        },
        {
          "type": "Container",
          "id": "lastDecisionsContent",
          "isVisible": true,
          "spacing": "Small",
          "items": [
            {
              "type": "TextBlock",
              "text": "${last_meeting_date}",
              "size": "Small",
              "isSubtle": true
            },
            {
              "type": "TextBlock",
              "text": "${last_meeting_decisions}",
              "wrap": true,
              "size": "Small",
              "spacing": "Small"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "$when": "${has_related_documents}",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Related Documents",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["relatedDocsContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${related_documents}",
          "wrap": true,
          "id": "relatedDocsContent",
          "isVisible": true,
          "spacing": "Small",
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "AI-Suggested Questions",
          "weight": "Bolder",
          "size": "Medium",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "${suggested_questions}",
          "wrap": true,
          "spacing": "Small",
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Small",
      "items": [
        {
          "type": "TextBlock",
          "text": "Powered by CXO AI Companion | AI-generated brief | ${model_used}",
          "size": "Small",
          "isSubtle": true,
          "horizontalAlignment": "Center"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Join Meeting",
      "url": "${join_url}",
      "style": "positive",
      "iconUrl": "https://img.icons8.com/fluency/24/video-call.png"
    },
    {
      "type": "Action.Submit",
      "title": "Request Deeper Analysis",
      "data": {
        "action": "deep_analysis",
        "meeting_id": "${meeting_id}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Dismiss",
      "data": {
        "action": "dismiss_brief",
        "meeting_id": "${meeting_id}"
      }
    }
  ]
}
