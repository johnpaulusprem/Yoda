# ─── CXO AI Companion — Environment Configuration ──────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ─── Application ────────────────────────────────────────────────────────────
APP_NAME=cxo-ai-companion
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
# Public URL for webhook callbacks (ngrok URL for local dev)
BASE_URL=https://your-app.azurecontainerapps.io

# ─── Database (PostgreSQL + asyncpg) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cxo:localdev@localhost:5432/cxo_companion
# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Azure Entra ID (formerly Azure AD) — App Registration ─────────────────
# Required: daemon flow (app-only, no user interaction)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ─── Azure Communication Services (ACS) ────────────────────────────────────
# Required: for Teams call automation and recording
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=your-key
ACS_ENDPOINT=https://your-acs.communication.azure.com

# ─── Azure AI Foundry (GPT-4o / GPT-4o-mini) ──────────────────────────────
AI_FOUNDRY_ENDPOINT=https://your-ai-foundry.openai.azure.com/
AI_FOUNDRY_API_KEY=your-ai-foundry-api-key
AI_FOUNDRY_DEPLOYMENT_PRIMARY=gpt-4o
AI_FOUNDRY_DEPLOYMENT_FAST=gpt-4o-mini

# ─── Graph API ──────────────────────────────────────────────────────────────
# Scopes are configured in app registration; these are for reference
GRAPH_API_BASE_URL=https://graph.microsoft.com/v1.0
# Comma-separated list of CXO user principal names to monitor
MONITORED_USERS=ceo@contoso.com,cto@contoso.com,cfo@contoso.com

# ─── Observability (optional) ──────────────────────────────────────────────
# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cxo-ai-companion

# ─── Azure OpenAI Embeddings (for RAG pipeline) ───────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_EMBEDDING_KEY=your-embedding-api-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── RAG / Chunking ───────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─── DSPy ─────────────────────────────────────────────────────────────────
DSPY_CACHE_ENABLED=true
DSPY_CACHE_TTL=3600

# ─── Security ──────────────────────────────────────────────────────────────
# Webhook validation secret for Graph change notifications
GRAPH_WEBHOOK_SECRET=your-webhook-validation-secret
# API key for internal service-to-service calls (if needed)
INTERNAL_API_KEY=your-internal-api-key
