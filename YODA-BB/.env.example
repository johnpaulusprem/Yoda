# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yoda:yoda_dev@localhost:5432/yoda
REDIS_URL=redis://localhost:6379/0

# ── Azure Entra ID (App Registration) ────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── Azure AI Foundry (LLM) ───────────────────────────────────────
AI_FOUNDRY_ENDPOINT=https://your-ai-foundry.openai.azure.com/
AI_FOUNDRY_API_KEY=your-ai-foundry-api-key
AI_FOUNDRY_DEPLOYMENT=gpt-4o-mini

# ── Azure OpenAI Embeddings ──────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-embedding-endpoint.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=your-embedding-api-key
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure Communication Services ─────────────────────────────────
ACS_CONNECTION_STRING=endpoint=https://your-acs.communication.azure.com/;accesskey=...
ACS_ENDPOINT=https://your-acs.communication.azure.com

# ── Public URLs ───────────────────────────────────────────────────
BASE_URL=https://your-public-url.azurecontainerapps.io
BROWSER_BOT_BASE_URL=http://localhost:3978
BROWSER_BOT_API_KEY=your-browser-bot-api-key

# ── CORS (Frontend) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:4200"]

# ── Auth ────────────────────────────────────────────────────────
REQUIRE_AUTH=false

# ── Inter-Service Authentication ──────────────────────────────────
INTER_SERVICE_HMAC_KEY=generate-a-random-256-bit-key-here
