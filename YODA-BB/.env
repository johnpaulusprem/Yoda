# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yoda:yoda_dev@localhost:5432/yoda
REDIS_URL=redis://localhost:6379/0

# ── Azure Entra ID (App Registration) ────────────────────────────
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=11111111-1111-1111-1111-111111111111
AZURE_CLIENT_SECRET=dummy-client-secret-value

# ── Azure AI Foundry (LLM) ───────────────────────────────────────
AI_FOUNDRY_ENDPOINT=https://dummy-ai-foundry.openai.azure.com/
AI_FOUNDRY_API_KEY=dummy-ai-foundry-api-key-12345
AI_FOUNDRY_DEPLOYMENT=gpt-4o-mini

# ── Azure OpenAI Embeddings ──────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://dummy-embedding.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=dummy-embedding-api-key-12345
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure Communication Services ─────────────────────────────────
ACS_CONNECTION_STRING=endpoint=https://dummy-acs.communication.azure.com/;accesskey=dummyaccesskey12345
ACS_ENDPOINT=https://dummy-acs.communication.azure.com

# ── Public URLs ───────────────────────────────────────────────────
BASE_URL=http://localhost:8000
BROWSER_BOT_BASE_URL=http://localhost:3978
BROWSER_BOT_API_KEY=dummy-browser-bot-api-key

# ── CORS (Frontend) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:4210"]

# ── Auth ────────────────────────────────────────────────────────
REQUIRE_AUTH=false

# ── Inter-Service Authentication ──────────────────────────────────
INTER_SERVICE_HMAC_KEY=dummy-hmac-key-replace-with-random-256-bit-value
