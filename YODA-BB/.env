# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://yoda:yoda_dev@localhost:5432/yoda
REDIS_URL=redis://localhost:6379/0

# ── Azure Entra ID (App Registration) ────────────────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Azure AI Foundry (LLM) ───────────────────────────────────────
AI_FOUNDRY_ENDPOINT=
AI_FOUNDRY_API_KEY=
AI_FOUNDRY_DEPLOYMENT=gpt-4o-mini

# ── Azure OpenAI Embeddings ──────────────────────────────────────
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ── Azure Communication Services ─────────────────────────────────
ACS_CONNECTION_STRING=
ACS_ENDPOINT=

# ── Public URLs ───────────────────────────────────────────────────
BASE_URL=http://localhost:8010
BROWSER_BOT_BASE_URL=http://localhost:3978
BROWSER_BOT_API_KEY=

# ── CORS (Frontend) ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:4200","http://localhost:4210"]

# ── Auth ────────────────────────────────────────────────────────
REQUIRE_AUTH=false

# ── Inter-Service Authentication ──────────────────────────────────
INTER_SERVICE_HMAC_KEY=dev-local-key-not-for-production
