{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://img.icons8.com/fluency/48/calendar-week.png",
              "size": "Small",
              "style": "Default"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Weekly Meeting Digest",
              "weight": "Bolder",
              "size": "Large"
            },
            {
              "type": "TextBlock",
              "text": "${week_range}",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Week at a Glance",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "ColumnSet",
          "spacing": "Small",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${total_meetings}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "Meetings",
                  "size": "Small",
                  "horizontalAlignment": "Center",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${total_action_items}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "Action Items",
                  "size": "Small",
                  "horizontalAlignment": "Center",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${completion_rate}%",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Good"
                },
                {
                  "type": "TextBlock",
                  "text": "Completion Rate",
                  "size": "Small",
                  "horizontalAlignment": "Center",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "${total_decisions}",
                  "weight": "Bolder",
                  "size": "ExtraLarge",
                  "horizontalAlignment": "Center",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "Decisions",
                  "size": "Small",
                  "horizontalAlignment": "Center",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Meetings This Week",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["meetingsListContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${meetings_list}",
          "wrap": true,
          "id": "meetingsListContent",
          "isVisible": true,
          "spacing": "Small",
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Open Action Items by Assignee",
                  "weight": "Bolder",
                  "size": "Medium"
                }
              ]
            },
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Show/Hide",
                  "color": "Accent",
                  "size": "Small"
                }
              ],
              "selectAction": {
                "type": "Action.ToggleVisibility",
                "targetElements": ["actionItemsByAssigneeContent"]
              }
            }
          ]
        },
        {
          "type": "TextBlock",
          "text": "${action_items_by_assignee}",
          "wrap": true,
          "id": "actionItemsByAssigneeContent",
          "isVisible": true,
          "spacing": "Small",
          "size": "Small"
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Completion Statistics",
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "FactSet",
          "spacing": "Small",
          "facts": [
            {
              "title": "Completed:",
              "value": "${completed_count} items"
            },
            {
              "title": "In Progress:",
              "value": "${in_progress_count} items"
            },
            {
              "title": "Pending:",
              "value": "${pending_count} items"
            },
            {
              "title": "Overdue:",
              "value": "${overdue_count} items"
            },
            {
              "title": "Total Hours in Meetings:",
              "value": "${total_meeting_hours}"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Small",
      "items": [
        {
          "type": "TextBlock",
          "text": "Powered by Meeting Assistant | Generated ${generated_at}",
          "size": "Small",
          "isSubtle": true,
          "horizontalAlignment": "Center"
        }
      ]
    }
  ]
}
