{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://img.icons8.com/fluency/48/alarm-clock.png",
              "size": "Small",
              "style": "Default"
            }
          ],
          "verticalContentAlignment": "Center"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "Action Item Reminder",
              "weight": "Bolder",
              "size": "Large",
              "color": "Attention"
            },
            {
              "type": "TextBlock",
              "text": "You have an action item that needs your attention",
              "size": "Small",
              "isSubtle": true,
              "spacing": "None",
              "wrap": true
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "${description}",
          "wrap": true,
          "weight": "Bolder",
          "size": "Medium"
        },
        {
          "type": "FactSet",
          "spacing": "Medium",
          "facts": [
            {
              "title": "Meeting:",
              "value": "${meeting_subject}"
            },
            {
              "title": "Meeting Date:",
              "value": "${meeting_date}"
            },
            {
              "title": "Deadline:",
              "value": "${deadline}"
            },
            {
              "title": "Priority:",
              "value": "${priority}"
            },
            {
              "title": "Status:",
              "value": "${status}"
            },
            {
              "title": "Reminder #:",
              "value": "${nudge_number}"
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "separator": true,
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "${deadline_message}",
          "wrap": true,
          "color": "${deadline_color}",
          "weight": "Bolder",
          "size": "Small"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Submit",
      "title": "Mark Complete",
      "style": "positive",
      "data": {
        "action": "complete",
        "item_id": "${item_id}"
      }
    },
    {
      "type": "Action.Submit",
      "title": "Snooze 1 Day",
      "data": {
        "action": "snooze",
        "item_id": "${item_id}",
        "days": 1
      }
    },
    {
      "type": "Action.Submit",
      "title": "Update Status",
      "data": {
        "action": "update",
        "item_id": "${item_id}"
      }
    }
  ]
}
